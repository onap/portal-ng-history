<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2" author="portal-ng" dbms="postgresql">
        <!-- getActions filters by user_id + action_created_at and sorts by action_created_at DESC -->
        <createIndex tableName="actions" indexName="idx_actions_user_id_created_at">
            <column name="user_id"/>
            <column name="action_created_at"/>
        </createIndex>
        <!-- listActions and the retention delete filter by action_created_at only -->
        <createIndex tableName="actions" indexName="idx_actions_created_at">
            <column name="action_created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
